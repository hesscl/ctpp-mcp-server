{
  "name": "ctpp-mcp",
  "version": "1.2.0",
  "description": "MCP server for the Census Transportation Planning Products (CTPP) Data API",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "inspect": "npx @modelcontextprotocol/inspector dist/index.js",
    "generate-geo-data": "npx tsx ../scripts/generate-geo-data.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
